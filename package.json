{
  "name": "@pie-lib/pie-lib",
  "description": "the pie-libs mono repo",
  "private": true,
  "license": "MIT",
  "config": {
    "scope": "none"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "static": "./scripts/static",
    "test": "./scripts/test",
    "dev": "./scripts/dev",
    "lint": "scripts/build lint",
    "clean": "scripts/build clean",
    "release": "scripts/build release deploy",
    "release:next": "scripts/build release deploy --next",
    "build": "scripts/build build",
    "postinstall": "lerna bootstrap",
    "prepush": "npm run test",
    "prepack": "scripts/build changelog",
    "run-mathml": "cd node_modules/ && yarn link \"@pie-framework/mathml-to-latex\" && cd .. && ./scripts/dev",
    "clean-install": "git clean -xdf . && yarn install && lerna bootstrap && ./scripts/build babel",
    "link-pslb": "cd node_modules/ && yarn link '@pslb/pslb'",
    "print-module": "time yarn pslb --config pslb/pslb.config.js --logLevel silly",
    "clean-print-module": "yarn clean-install && yarn print-module"
  },
  "devDependencies": {
    "@babel/cli": "^7.2.3",
    "@babel/core": "^7.3.3",
    "@babel/eslint-parser": "^7.23.0",
    "@babel/plugin-proposal-class-properties": "^7.3.3",
    "@babel/plugin-proposal-export-default-from": "^7.2.0",
    "@babel/plugin-proposal-export-namespace-from": "^7.2.0",
    "@babel/plugin-syntax-optional-catch-binding": "^7.8.3",
    "@babel/plugin-transform-runtime": "^7.28.3",
    "@babel/preset-env": "^7.3.1",
    "@babel/preset-react": "^7.0.0",
    "@pie-framework/build-helper": "^5.2.9",
    "@pie-lib/test-utils": "^0.8.0",
    "@pslb/pslb": "^4.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^16.3.0",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/fs-extra": "^5.0.5",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "babel-core": "7.0.0-bridge.0",
    "babel-jest": "^29.7.0",
    "babel-loader": "^8.0.5",
    "chalk": "4.1.2",
    "chokidar": "^5.0.0",
    "css-loader": "^2.1.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "file-loader": "^3.0.1",
    "fs-extra": "^7.0.1",
    "husky": "^4.2.5",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "26.1.0",
    "lerna": "^3.11.0",
    "lint-staged": "^8.1.5",
    "lodash": "^4.17.11",
    "minimist": "^1.2.0",
    "next": "^15.4.6",
    "now": "^13.1.3",
    "prettier": "^1.15.3",
    "pretty-quick": "^1.10.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "regenerator-runtime": "^0.13.1",
    "semver": "^5.6.0",
    "url-loader": "^1.1.2",
    "webpack": "^4.28.4",
    "webpack-cli": "^3.2.1",
    "webpack-dev-server": "^3.1.14",
    "yarn": "^1.13.0"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.3",
    "core-js": "^3.47.0",
    "next-transpile-modules": "^10.0.1"
  },
  "workspaces": [
    "packages/*"
  ],
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
