#!/usr/bin/env node
const _ = require('lodash');
const minimist = require('minimist');
const { Commands } = require('@pie-framework/build-helper');
const args = minimist(process.argv.slice(2));
const { resolve } = require('path');

class LibCommands extends Commands {
  async deploy() {
    const demoDir = resolve(this.projectRoot, 'packages', 'demo');
    const next = this.bin('next');
    await this.runCmds([`${next} build`, `${next} export`], { cwd: demoDir });

    const alias = `pie-lib${args.next ? '-next' : ''}`;
    return this.staticToNow(resolve(demoDir, 'out'), alias);
  }

  sharedBuild() {
    if (args.next) {
      return Promise.resolve();
    } else {
      return this.runCmd(
        `yarn pslb --config pslb/pslb.config.js --publishLibs --token ${args.token} --cleanLibs --logLevel debug`
      );
    }
  }

  babel() {
    return super.babel().then(() => this.postBabel());
  }

  postBabel() {
    return super.runCmds([
      `node scripts/copy-external-imports.js`,
    ]);
  }

  build() {
    return super.build().then(() => this.sharedBuild());
  }

  async release() {
    // Configure git user for CI environments (needed for lerna version commits)
    try {
      await this.runCmd('git config user.email "ci@pie-framework.org"');
      await this.runCmd('git config user.name "CircleCI"');
    } catch (e) {
      // Git config might already be set or not in git repo, continue
    }
    
    // Step 1: Bump versions based on conventional commits, using current package.json
    // versions as the base (e.g., 6.1.0-next.0 -> 6.1.0-next.1)
    const lernaCmd = this.bin('lerna');
    const versionArgs = ['version', '--conventional-commits', '--yes'];
    
    if (args.next) {
      versionArgs.push('--conventional-prerelease');
    }
    
    console.log('Bumping versions based on conventional commits (using package.json as base)...');
    await this.runCmd(`${lernaCmd} ${versionArgs.join(' ')}`);
    
    // Step 2: Publish the bumped versions
    const publishArgs = ['publish', 'from-package', '--yes'];
    
    if (args.next) {
      publishArgs.push('--dist-tag', 'next');
    }
    if (args.skipForcePublish) {
      publishArgs.push('--skip-force-publish');
    }
    if (args.token) {
      publishArgs.push('--registry-auth-token', args.token);
    }
    
    console.log('Publishing packages with bumped versions...');
    await this.runCmd(`${lernaCmd} ${publishArgs.join(' ')}`);
    
    // If publishing to 'next', ensure the 'next' tag points to the latest version
    // This ensures @next always resolves to the newest next version
    if (args.next) {
      console.log('Ensuring @next tag points to latest versions...');
      const { getPackages } = require('@pie-framework/build-helper');
      const pkgs = getPackages(resolve(this.projectRoot, 'packages'));
      const npmCmd = this.bin('npm');
      
      for (const pkg of pkgs) {
        if (!pkg.pkg.private && pkg.pkg.name && pkg.pkg.version) {
          try {
            // Check if current version exists on npm (was just published)
            const viewCmd = `${npmCmd} view ${pkg.pkg.name}@${pkg.pkg.version} version --json`;
            const publishedVersion = await this.runCmd(viewCmd, { silent: true }).catch(() => '');
            
            if (publishedVersion && publishedVersion.trim() === `"${pkg.pkg.version}"`) {
              // This version was just published, explicitly ensure 'next' tag points to it
              // This guarantees @next resolves to the latest version
              await this.runCmd(`${npmCmd} dist-tag add ${pkg.pkg.name}@${pkg.pkg.version} next`, { silent: true });
              console.log(`  Ensured ${pkg.pkg.name}@next -> ${pkg.pkg.version}`);
            }
          } catch (e) {
            // Package might not exist or wasn't published, skip
          }
        }
      }
    }
    
    // After publishing, update dependencies only in packages that depend on
    // the newly published packages. This avoids triggering republishing of
    // unchanged packages.
    console.log('Updating dependencies in packages that depend on newly published packages...');
    await this.runCmd('node scripts/update-internal-deps.js');
  }
}

const cmds = new LibCommands(resolve(__dirname, '..'), args);

cmds
  .execute()
  .then(() => {
    console.log('all done');
    process.exit(0);
  })
  .catch(e => {
    console.error(e);
    process.exit(1);
  });
